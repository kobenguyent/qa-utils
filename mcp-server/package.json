{
  "name": "qa-utils-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for qa-utils - enables AI agents to interact with QA utility tools",
  "type": "module",
  "main": "dist/mcp-server/src/index.js",
  "bin": {
    "qa-utils-mcp": "dist/mcp-server/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp-server/src/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "qa-utils",
    "ai-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.0.2",
    "vitest": "^1.0.4"
  }
}
